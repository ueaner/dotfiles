# vim: set filetype=dosini:
image=~/.local/share/backgrounds/default.jxl
scaling=fill

# https://github.com/swaywm/swaylock/blob/master/main.c@set_default_colors

# background
color=#0e1f38
# backspace highlight
bs-hl-color=#e85c3a
# key highlight
key-hl-color=#4db8ff
# caps lock backspace highlight
caps-lock-bs-hl-color=#e85c3a
# caps lock key highlight
caps-lock-key-hl-color=#e8c44a

# separator (transparent for clean glass look)
separator-color=#ffffff00

# layout background
layout-bg-color=#0e1f38e0
# layout border
layout-border-color=#4480ba30
# layout text
layout-text-color=#c0ddf5

# input
inside-color=#0e1f38c0
# cleared
inside-clear-color=#e8c44a20
# caps lock
inside-caps-lock-color=#0e1f38c0
# verifying
inside-ver-color=#4db8ff20
# wrong
inside-wrong-color=#e85c3a20

# line (transparent — ring meets inside seamlessly)
line-color=#ffffff00
# cleared
line-clear-color=#ffffff00
# caps lock
line-caps-lock-color=#ffffff00
# verifying
line-ver-color=#ffffff00
# wrong
line-wrong-color=#ffffff00

# input
ring-color=#2060a0
# cleared
ring-clear-color=#e8c44a
# caps lock
ring-caps-lock-color=#e8c44a
# verifying
ring-ver-color=#4db8ff
# wrong
ring-wrong-color=#e85c3a

# input
text-color=#c0ddf5
# cleared
text-clear-color=#e8c44a
# caps lock
text-caps-lock-color=#e8c44a
# verifying
text-ver-color=#4db8ff
# wrong
text-wrong-color=#e85c3a
